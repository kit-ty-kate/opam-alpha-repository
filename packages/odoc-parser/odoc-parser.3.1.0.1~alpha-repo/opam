depends: [
  "dune" {>= "3.21"}
  "ocaml" {>= "4.08.0" & < "5.6"}
  "astring"
  "camlp-streams"
  "ppx_expect" {with-test}
  "sexplib0" {with-test}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@src/parser/runtest" {with-test}
  ]
]
